{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "node .next/standalone/server.js",
    "start:next": "node .next/standalone/server.js",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test --project=smoke --project=setup --project=critical --project=auth --project=rbac --project=navigation --project=dashboard --project=workflows --project=negative",
    "test:e2e:smoke": "playwright test --project=smoke",
    "test:e2e:smoke:local": "E2E_BASE_URL=http://127.0.0.1:8082 E2E_API_URL=http://127.0.0.1:8014 playwright test --project=smoke",
    "test:e2e:workflow": "playwright test --project=workflow-gate",
    "test:e2e:workflow:local": "E2E_BASE_URL=http://127.0.0.1:8082 E2E_API_URL=http://127.0.0.1:8014 playwright test --project=workflow-gate",
    "test:e2e:critical": "playwright test --project=setup --project=critical",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report ../output/playwright/report",
    "test:e2e:codegen": "playwright codegen",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:auth": "playwright test --project=auth",
    "test:e2e:rbac": "playwright test --project=rbac",
    "test:e2e:navigation": "playwright test --project=navigation",
    "test:e2e:dashboard": "playwright test --project=dashboard",
    "test:e2e:workflows": "playwright test --project=workflows",
    "test:e2e:negative": "playwright test --project=negative",
    "test:e2e:regression": "playwright test --project=setup --project=critical --project=workflows --project=negative --project=rbac",
    "test:e2e:screenshots": "playwright test --project=screenshots",
    "test:e2e:full": "playwright test"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.5",
    "axios": "^1.12.2",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.23.24",
    "lucide-react": "^0.546.0",
    "next": "14.2.33",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^3.3.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.33",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
